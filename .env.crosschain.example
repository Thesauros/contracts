# Crosschain deployment env (Base home + Arbitrum remote, Stargate-only)
#
# Never commit real keys. Copy to `.env` or export in your shell.

# RPCs
BASE_RPC_URL=
ARBITRUM_RPC_URL=

# Signer key (use one key for both, or set different keys and export before each command)
PRIVATE_KEY=

# Role addresses (can be the deployer for rehearsal)
GOVERNANCE=
KEEPER=
ALLOCATOR=
REPORT_ATTESTOR=

# Asset on both chains (set DEPLOY_MOCK_ASSET=true to deploy MockERC20 instead)
DEPLOY_MOCK_ASSET=false
ASSET=
ASSET_DECIMALS=6

# Vault metadata (home chain only)
VAULT_NAME="CrossChain Vault (Home)"
VAULT_SYMBOL="ccHOME"

# Strategy bootstrap (home chain)
UPSERT_STRATEGY=false
STRATEGY_ID=1
REMOTE_CHAIN_ID=
REMOTE_AGENT=

# Remote chain rehearsal path (optional)
DEPLOY_MOCK_ERC4626=true
ERC4626_VAULT=

# Stargate/LayerZero peer wiring
# You must set the correct EIDs for Base/Arbitrum and peer bytes32 values.
BASE_EID=
ARBITRUM_EID=
HOME_BRIDGE_ADAPTER=
REMOTE_BRIDGE_ADAPTER=
HOME_PEER=
REMOTE_PEER=

