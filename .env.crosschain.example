# Crosschain deployment env (Base home + Arbitrum remote, Stargate-only)
#
# Never commit real keys. Copy to `.env` or export in your shell.

# RPCs
BASE_RPC_URL=
ARBITRUM_RPC_URL=

# Signer key (use one key for both, or set different keys and export before each command)
PRIVATE_KEY=

# Role addresses (can be the deployer for rehearsal)
GOVERNANCE=
KEEPER=
ALLOCATOR=
REPORT_ATTESTOR=
REPORTER=
GUARDIAN=

# Asset/adapters by chain.
# Scripts still accept generic ASSET / AAVE_POOL_ADDRESSES_PROVIDER / META_MORPHO,
# but if those are omitted they will auto-resolve from the current chain.
DEPLOY_MOCK_ASSET=false
USDC_Base=
USDC_Arbitrum=
AAVE_POOL_ADDRESSES_PROVIDER_BASE=
AAVE_POOL_ADDRESSES_PROVIDER_ARBITRUM=
META_MORPHO_BASE=
ASSET_DECIMALS=6

# Vault metadata (home chain only)
VAULT_NAME="CrossChain Vault (Home)"
VAULT_SYMBOL="ccHOME"

# Strategy bootstrap (home chain)
UPSERT_STRATEGY=false
STRATEGY_ID=1
REMOTE_CHAIN_ID=
REMOTE_AGENT=

# Remote chain rehearsal path (optional)
DEPLOY_MOCK_ERC4626=true
ERC4626_VAULT=

# Stargate/LayerZero peer wiring
# ConfigureStargatePeers accepts either explicit PEER_EID or PEER_CHAIN_ID.
EID_Stargate_BASE=
EID_Stargate_Arbitrum=
HOME_BRIDGE_ADAPTER=
REMOTE_BRIDGE_ADAPTER=
HOME_PEER=
REMOTE_PEER=

# Real Stargate transport
STARGATE=
LAYERZERO_ENDPOINT_V2=
STARGATE_SEND_OPTIONS=
STRATEGY_RECEIVER=

# Confirmed Base <-> Arbitrum production transport references
# Sources:
# - Stargate mainnet contracts docs
# - LayerZero EndpointV2 on-chain eid() checks
#
# Runtime scripts still read the generic vars above. Export the chain-specific
# values below into STARGATE / LAYERZERO_ENDPOINT_V2 / STARGATE_SEND_OPTIONS
# before each `forge script` invocation.
STARGATE_BASE=0x27a16dc786820B16E5c9028b75B99F6f604b5d26
STARGATE_ARBITRUM=0xe8CDF27AcD73a434D661C84887215F7598e7d0d3
LAYERZERO_ENDPOINT_V2_BASE=0x1a44076050125825900e736c501f859c50fE728c
LAYERZERO_ENDPOINT_V2_ARBITRUM=0x1a44076050125825900e736c501f859c50fE728c

# Baseline Stargate compose-only extraOptions:
# TYPE_3 + Executor(worker=1) + LZCOMPOSE(type=3,index=0,gas=200000,value=0)
# This follows Stargate's compose example and LayerZero TYPE_3 option format.
# Profile and raise the compose gas if remote execution proves more expensive.
STARGATE_SEND_OPTIONS_BASE_TO_ARBITRUM=0x00030100130300000000000000000000000000000000030d40
STARGATE_SEND_OPTIONS_ARBITRUM_TO_BASE=0x00030100130300000000000000000000000000000000030d40
