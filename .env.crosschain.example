# Crosschain deployment env (Base home + Arbitrum remote, Stargate-only)
#
# Never commit real keys. Copy to `.env` or export in your shell.

# RPCs
BASE_RPC_URL=
ARBITRUM_RPC_URL=

# Signer key (use one key for both, or set different keys and export before each command)
PRIVATE_KEY=

# Role addresses (can be the deployer for rehearsal)
GOVERNANCE=
KEEPER=
ALLOCATOR=
REPORT_ATTESTOR=
REPORTER=
GUARDIAN=

# Asset/adapters by chain.
# Scripts still accept generic ASSET / AAVE_POOL_ADDRESSES_PROVIDER / META_MORPHO,
# but if those are omitted they will auto-resolve from the current chain.
DEPLOY_MOCK_ASSET=false
USDC_Base=
USDC_Arbitrum=
AAVE_POOL_ADDRESSES_PROVIDER_BASE=
AAVE_POOL_ADDRESSES_PROVIDER_ARBITRUM=
META_MORPHO_BASE=
ASSET_DECIMALS=6

# Vault metadata (home chain only)
VAULT_NAME="CrossChain Vault (Home)"
VAULT_SYMBOL="ccHOME"

# Strategy bootstrap (home chain)
UPSERT_STRATEGY=false
STRATEGY_ID=1
REMOTE_CHAIN_ID=
REMOTE_AGENT=

# Remote chain rehearsal path (optional)
DEPLOY_MOCK_ERC4626=true
ERC4626_VAULT=

# Stargate/LayerZero peer wiring
# ConfigureStargatePeers accepts either explicit PEER_EID or PEER_CHAIN_ID.
EID_Stargate_BASE=
EID_Stargate_Arbitrum=
HOME_BRIDGE_ADAPTER=
REMOTE_BRIDGE_ADAPTER=
HOME_PEER=
REMOTE_PEER=
